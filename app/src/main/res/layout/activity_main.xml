<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".MainActivity">

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFocus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus"
            app:chipStrokeWidth="2dp"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipBreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Break"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipRest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rest"/>

    </com.google.android.material.chip.ChipGroup>


    <!-- TIMER -->

    <TextView
        android:id="@+id/tvTimerDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25:00"
        android:textSize="72sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/chipGroupMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>


    <!-- FRASE MOTIVACIONAL -->

    <TextView
        android:id="@+id/tvQuote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready to focus?"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvTimerDisplay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>


    <LinearLayout
        android:id="@+id/sessionDotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvQuote"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>


    <TextView
        android:id="@+id/tvSessionCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sesiones: 0"
        app:layout_constraintTop_toBottomOf="@id/sessionDotsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>


    <Button
        android:id="@+id/btnStartStop"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Start"
        app:layout_constraintTop_toBottomOf="@id/tvSessionCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>


    <!-- CONTROLES EXTRA -->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/btnStartStop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnReset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset"/>

        <Button
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:layout_marginStart="16dp"/>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>